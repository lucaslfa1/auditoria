# ==============================================================================
# Auditoria NSTECH — backend/.env.example
# ------------------------------------------------------------------------------
# Template COMPLETO das variáveis de ambiente lidas pelo backend (FastAPI).
# Copie para `backend/.env` e preencha os valores. NUNCA commite o .env real.
#
# Convenções deste arquivo:
#   - [CUSTO]   = variável que gera ou controla custo de API paga (Azure).
#   - (env>DB)  = também pode ser definida na tabela `configuracoes` do banco;
#                 a variável de ambiente tem precedência sobre o banco.
#   - O valor mostrado é o DEFAULT do código (vazio = sem default / obrigatória).
#
# Ordem de carga do dotenv (override=False, primeira definição vence no SO):
#   1) variáveis já exportadas no ambiente  2) <raiz>/.env  3) backend/.env
# ==============================================================================


# ------------------------------------------------------------------------------
# GERAL / RUNTIME
# ------------------------------------------------------------------------------
# Ambiente: "development" ou "production" (production ativa validação estrita de
# credenciais, cookies secure, rate limits e storage GCS). Default: development
ENVIRONMENT=development

# Porta HTTP do uvicorn (Cloud Run injeta automaticamente). Default: 8080
PORT=8080

# Origens permitidas no CORS, separadas por vírgula. Default: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sobrescreve a versão exibida em /api/system/version (default: deduzida de
# package.json + logs/versions/). Normalmente deixar vazio.
APP_VERSION=

# Modo determinístico das chamadas de IA (temperatura 0 etc.). Default: true
DETERMINISTIC_MODE=true


# ------------------------------------------------------------------------------
# BANCO DE DADOS (Neon PostgreSQL — psycopg2)
# ------------------------------------------------------------------------------
# Connection string do Postgres. OBRIGATÓRIA em production (sem fallback).
# Em development, se vazia, cai em postgresql://postgres:postgres@localhost:5432/auditoria
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# application_name reportado ao Postgres (observabilidade). Default: auditoria_api
DB_APPLICATION_NAME=auditoria_api

# Aplica timeouts de sessão (statement/lock/idle) em cada conexão. Default: true
DB_SESSION_TIMEOUTS_ENABLED=true

# Timeout de statement SQL em ms. Default: 120000
DB_STATEMENT_TIMEOUT_MS=120000

# Timeout de lock em ms. Default: 10000
DB_LOCK_TIMEOUT_MS=10000

# Timeout de transação ociosa (idle_in_transaction) em ms. Default: 60000
DB_IDLE_IN_TX_TIMEOUT_MS=60000

# Timeout de conexão TCP ao Postgres, em segundos. Default: 5
# (DB_CONNECT_TIMEOUT é o nome legado, ainda aceito como fallback)
DB_CONNECT_TIMEOUT_SECONDS=5

# Tamanho do pool de conexões. Defaults: min 1 / max 20
DB_POOL_MIN_CONN=1
DB_POOL_MAX_CONN=20

# Tempo máximo (s) aguardando conexão livre no pool. Default: 10.0
DB_POOL_WAIT_SECONDS=10.0

# Valida a conexão (SELECT 1) ao retirar do pool. Default: true
DB_POOL_VALIDATE_ON_CHECKOUT=true


# ------------------------------------------------------------------------------
# AUTH E SESSÃO
# ------------------------------------------------------------------------------
# Segredo de assinatura do cookie de sessão. OBRIGATÓRIO em production.
SESSION_SECRET=<gere-um-segredo-forte-aleatorio>

# Validade da sessão em segundos. Default: 28800 (8h)
SESSION_TTL_SECONDS=28800

# Cookie com flag Secure (exige HTTPS). Default: true em production, false em dev
SESSION_COOKIE_SECURE=false

# Rate limit do endpoint de login. Default: habilitado apenas em production
ENABLE_LOGIN_RATE_LIMIT=false
# Tentativas de login permitidas por janela. Default: 5
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
# Janela do rate limit de login, em segundos. Default: 300
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Seed de usuários no bootstrap de banco vazio (lista JSON inline). Em production
# é OBRIGATÓRIO definir AUTH_USERS_JSON ou AUTH_USERS_FILE. Ex.:
# AUTH_USERS_JSON=[{"username":"admin","password":"<troque-me>","role":"admin"}]
AUTH_USERS_JSON=

# Alternativa: caminho de arquivo JSON com a lista de usuários para seed.
# (o antigo backend/auth_users.json foi descontinuado — usuários vivem na tabela `users`)
AUTH_USERS_FILE=

# Seed automático de operadores a partir de JSON no init_db: auto|true|false.
# Default: auto (liga fora de testes). Normalmente não mexer.
AUDITORIA_SEED_OPERADORES_JSON=auto

# Rate limit global da API (todas as rotas). Default: habilitado em production
ENABLE_GLOBAL_RATE_LIMIT=false
# Máximo de requests por janela por chave (IP). Default: 200
GLOBAL_RATE_LIMIT_MAX_REQUESTS=200
# Janela do rate limit global, em segundos. Default: 60
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60
# Máximo de chaves (IPs) rastreadas em memória. Default: 10000
GLOBAL_RATE_LIMIT_MAX_KEYS=10000


# ------------------------------------------------------------------------------
# AZURE OPENAI — AVALIAÇÃO / AUDITORIA (GPT-4o)  [CUSTO]
# ------------------------------------------------------------------------------
# Endpoint do recurso Azure OpenAI usado na avaliação de auditoria. OBRIGATÓRIO. [CUSTO]
AZURE_OPENAI_ENDPOINT=https://azure-openai-opentech.openai.azure.com/

# API key do recurso acima. OBRIGATÓRIA. [CUSTO]
AZURE_OPENAI_KEY=<sua-chave-azure-openai>

# Nome do deployment do modelo de avaliação. Default: gpt-4o [CUSTO]
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Nome do deployment usado APENAS pela pré-triagem (core/pre_triage.py).
# Default: gpt-4o. Mantido por compatibilidade — normalmente igual ao de cima.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Timeout (s) da chamada de avaliação GPT-4o (clamp 30–600). Default: 180
AZURE_OPENAI_AUDIT_TIMEOUT_SECONDS=180

# Deployment de embeddings p/ RAG de triagem (rag_triagem.py). Default: text-embedding-ada-002 [CUSTO]
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# --- Legado (provider Gemini DESATIVADO em código; AI_ENABLED=False hardcoded) ---
# Prioridade de provider de IA: azure|primary. Default: azure (não mude sem refactor)
AI_PROVIDER_PRIORITY=azure
# Chave/modelo do provider "primary" (Gemini) — usados só por scripts manuais de teste.
AI_API_KEY=
AI_MODEL=gpt-4o
AI_AUDIT_MODEL=


# ------------------------------------------------------------------------------
# AZURE SPEECH — FAST TRANSCRIPTION (STT padrão)  [CUSTO]
# ------------------------------------------------------------------------------
# API key do recurso Speech. OBRIGATÓRIA para transcrever áudio. [CUSTO]
AZURE_SPEECH_KEY=<sua-chave-azure-speech>

# Endpoint REST do Speech (Fast Transcription API). [CUSTO]
AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/

# Região do recurso Speech (usada pelo Speech SDK alternativo; default sdk: eastus2)
AZURE_SPEECH_REGION=eastus

# Versão da Fast Transcription API. Default: 2025-10-15
AZURE_SPEECH_API_VERSION=2025-10-15

# Máximo de falantes pedidos à diarização do Speech. Default: 2
AZURE_SPEECH_MAX_SPEAKERS=2

# Tamanho máximo (bytes) de upload síncrono ao Speech. Default: 26214400 (25MB)
AZURE_SPEECH_MAX_SYNC_UPLOAD_BYTES=26214400


# ------------------------------------------------------------------------------
# AZURE WHISPER (fallback de transcrição)  [CUSTO]
# ------------------------------------------------------------------------------
# Endpoint/key/deployment do Whisper. Se vazios, caem no recurso AZURE_OPENAI_*
# usando AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT como nome do deployment. [CUSTO]
AZURE_WHISPER_ENDPOINT=https://adml-mobl85rw-eastus2.cognitiveservices.azure.com/
AZURE_WHISPER_KEY=<sua-chave-whisper>
AZURE_WHISPER_DEPLOYMENT=whisper

# Deployment de transcrição no recurso AZURE_OPENAI_* (fallback quando os
# AZURE_WHISPER_* acima estão vazios). Sem default.
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=

# Temperatura do Whisper (0 = determinístico, recomendado p/ telefonia). Default: 0
AZURE_WHISPER_TEMPERATURE=0

# Concorrência máxima de chamadas Whisper simultâneas. Default: 4
WHISPER_MAX_CONCURRENCY=4


# ------------------------------------------------------------------------------
# GPT-4o TRANSCRIBE-DIARIZE (transcrição premium)  [CUSTO]
# ------------------------------------------------------------------------------
# Endpoint/key/deployment do GPT-4o diarize. Se vazios, caem no recurso
# AZURE_OPENAI_* usando AZURE_OPENAI_TRANSCRIBE_DIARIZE_DEPLOYMENT. [CUSTO]
AZURE_GPT4O_DIARIZE_ENDPOINT=https://adml-mobl85rw-eastus2.cognitiveservices.azure.com/
AZURE_GPT4O_DIARIZE_KEY=<sua-chave-gpt4o-diarize>
AZURE_GPT4O_DIARIZE_DEPLOYMENT=gpt-4o-transcribe-diarize

# Nome do modelo (campo "model" do request). Default: gpt-4o-transcribe-diarize
AZURE_GPT4O_DIARIZE_MODEL=gpt-4o-transcribe-diarize

# Fallbacks legados p/ deployment/model quando os AZURE_GPT4O_DIARIZE_* estão vazios.
AZURE_OPENAI_TRANSCRIBE_DIARIZE_DEPLOYMENT=
AZURE_OPENAI_TRANSCRIBE_DIARIZE_MODEL=

# Autenticação: api_key | bearer. Vazio = auto-detecta pelo endpoint
# (*.cognitiveservices.azure.com => bearer; *.openai.azure.com => api_key)
AZURE_GPT4O_DIARIZE_AUTH_MODE=

# Score mínimo de qualidade p/ aceitar o resultado premium. Default: 0.82
AZURE_GPT4O_DIARIZE_MIN_SCORE=0.82

# Retries da chamada premium (cada retry é nova chamada paga). Default: 1 [CUSTO]
AZURE_GPT4O_DIARIZE_RETRY_COUNT=1

# Espera (s) entre retries do premium. Default: 1.5
AZURE_GPT4O_DIARIZE_RETRY_DELAY_SECONDS=1.5

# Setores (separados por vírgula) que usam o premium como engine PRIMÁRIA.
# Vazio = nenhum. [CUSTO]
AZURE_GPT4O_DIARIZE_PRIMARY_SECTORS=

# Smart routing: pré-scan barato decide se vale chamar o premium. Default: true [CUSTO]
AZURE_GPT4O_DIARIZE_SMART_ROUTING=true

# Duração (s) do trecho analisado no pré-scan. Default: 35
AZURE_GPT4O_DIARIZE_PRIMARY_PRESCAN_SECONDS=35

# Score mínimo do pré-scan p/ liberar o premium. Default: 0.58
AZURE_GPT4O_DIARIZE_PRIMARY_PRESCAN_MIN_SCORE=0.58


# ------------------------------------------------------------------------------
# TRANSCRIÇÃO — ENGINE, SELECTOR E JUDGE  [CUSTO]
# ------------------------------------------------------------------------------
# Engine padrão: fast | whisper | gpt4o_diarize | sdk | hybrid_dual.
# Default: fast (mais barata). hybrid_dual roda DOIS engines por áudio. [CUSTO]
AZURE_TRANSCRIPTION_ENGINE=fast

# Cadeia de fallback do engine "fast": cada flag abaixo libera UMA etapa extra
# (fast -> whisper -> gpt4o_diarize -> sdk). Defaults: todos false. [CUSTO]
AZURE_WHISPER_FALLBACK=false
AZURE_GPT4O_DIARIZE_FALLBACK=false
AZURE_PREMIUM_TRANSCRIPTION_FALLBACK=false
AZURE_SDK_FALLBACK=false

# Em engine=hybrid_dual, falha de um dos braços derruba o resultado (sem degradar
# silenciosamente para engine única). Default: true
AZURE_TRANSCRIPTION_STRICT_HYBRID_DUAL=true

# Seletor de candidatos: compara transcrições candidatas e escolhe a melhor.
# Desligar economiza chamadas extras. Default: true [CUSTO]
TRANSCRIPTION_CANDIDATE_SELECTOR_ENABLED=true

# Alertas críticos (substring no alert_id/label, separados por vírgula) que
# forçam caminho mais rigoroso no selector. Default:
# PRIORITARIO-POLICIA,PARADA-MOT,BOTAO-PANICO,SUSPEITA-SINISTRO [CUSTO]
TRANSCRIPTION_CRITICAL_ALERT_IDS=PRIORITARIO-POLICIA,PARADA-MOT,BOTAO-PANICO,SUSPEITA-SINISTRO

# OBS: o "judge" LLM (desempate do selector, transcription_judge.py) NÃO tem env
# própria — roda dentro do selector e consome chamadas GPT-4o quando há empate. [CUSTO]

# Timeout (s) de uma chamada de transcrição. Default: 600
AZURE_TRANSCRIPTION_TIMEOUT_SECONDS=600

# Timeout (s) da estratégia completa (engine + fallbacks). Default: timeout+240 (840)
AZURE_TRANSCRIPTION_STRATEGY_TIMEOUT_SECONDS=

# Pré-processamento de áudio (normalização etc.) antes do STT. Default: true
AZURE_PREPROCESS_ENABLED=true

# Tamanho mínimo (bytes) p/ converter lossless antes do upload. Default: 8388608 (8MB)
AZURE_LOSSLESS_PREPROCESS_MIN_BYTES=8388608


# ------------------------------------------------------------------------------
# AZURE TEXT ANALYTICS (sentimento)  [CUSTO]
# ------------------------------------------------------------------------------
# Endpoint/key do Language Service. Só usados se a análise estiver habilitada. [CUSTO]
AZURE_TEXT_ANALYTICS_ENDPOINT=https://azure-language-opentech.cognitiveservices.azure.com/
AZURE_TEXT_ANALYTICS_KEY=<sua-chave-text-analytics>

# Liga a análise de sentimento nas auditorias. Default: false [CUSTO]
ENABLE_SENTIMENT_ANALYSIS=false


# ------------------------------------------------------------------------------
# CLASSIFICAÇÃO / TRIAGEM
# ------------------------------------------------------------------------------
# Confiança abaixo da qual a classificação vai p/ revisão manual. Default: 0.8
LOW_CONFIDENCE_REVIEW_THRESHOLD=0.8

# Confiança mínima p/ confiar no setor vindo da classificação. Default: 0.9
SECTOR_TRUST_CONFIDENCE=0.9

# Guardrail EFETUADA vs RECEPTIVA por keyword no alert_id. Default: true
DIRECTION_GUARDRAIL_ENABLED=true

# Guardrail rígido de setor: força SEMPRE o setor oficial do RH (zera alerta p/
# desconhecido se divergir). Rollback: false. Default: true
STRICT_RH_SECTOR_ENFORCEMENT=true

# Canary: pular silêncio/URA inicial na janela de triagem. Default: false
CLASSIFICATION_TRIM_LEADING_SILENCE=false

# Fonte do catálogo de critérios: db (oficial) | yaml (legado/testes). Default: db
CRITERIA_CATALOG_SOURCE=db

# Concorrência máxima da classificação em lote da Telefonia. Default: 3
TELEFONIA_CLASSIFY_MAX_CONCURRENCY=3

# Telemetria interna de qualidade da auditoria (tabela própria). Default: true
AUDIT_INTERNAL_OBSERVABILITY_ENABLED=true

# Sincronização de "Arquivos Salvos" em fila assíncrona (não bloqueia request).
# Default: true
AUDIT_SAVED_FILES_ASYNC=true

# Tamanho máximo da fila assíncrona acima. Default: 10000
AUDIT_SAVED_FILES_QUEUE_MAX=10000


# ------------------------------------------------------------------------------
# GUARDRAILS DE CUSTO (core/cost_guard.py — ver docs/07-custos-e-guardrails.md)
# ------------------------------------------------------------------------------
# Teto DIÁRIO de chamadas LLM (Azure OpenAI: classificação+triagem+avaliação+judge).
# Atingiu o teto => pipeline para de pegar itens NOVOS (nada é descartado).
# <=0 desativa. (env>DB: cost_max_llm_calls_per_day) Default: 1500 [CUSTO]
COST_MAX_LLM_CALLS_PER_DAY=1500

# Teto DIÁRIO de auditorias completas (cada uma = várias chamadas pagas).
# <=0 desativa. (env>DB: cost_max_audits_per_day) Default: 200 [CUSTO]
COST_MAX_AUDITS_PER_DAY=200

# Kill-switch: true corta TODO consumo pago imediatamente.
# (env>DB: cost_kill_switch — dá pra cortar via UPDATE no banco, sem redeploy)
# Default: false [CUSTO]
COST_KILL_SWITCH=false

# Retry da avaliação quando a evidência ficou fraca. =0 desliga e corta a 2ª
# chamada GPT-4o (alavanca de custo). Default: true (1 retry) [CUSTO]
AUDIT_WEAK_EVIDENCE_RETRY=1

# Razão mínima de evidências casadas p/ NÃO disparar o retry acima.
# Default: 0.72 [CUSTO]
AUDIT_MIN_MATCHED_EVIDENCE_RATIO=0.72


# ------------------------------------------------------------------------------
# HUAWEI AICC (telefonia — credenciais também podem vir da tabela `configuracoes`
# com chave minúscula equivalente, ex.: huawei_ak; env tem precedência)
# ------------------------------------------------------------------------------
# Liga o sync Huawei (descoberta + download de gravações). Default: false [CUSTO]
ENABLE_HUAWEI_SYNC=false

# URLs do CMS e do File Service do tenant AICC. Defaults: brazilsaas.aicccloud.com:28443
HUAWEI_CMS_URL=https://brazilsaas.aicccloud.com:28443
HUAWEI_FS_URL=https://brazilsaas.aicccloud.com:28443

# Identificação do call center / VDN no AICC. (env>DB) Sem default.
HUAWEI_CC_ID=1
HUAWEI_VDN=25

# Credenciais AK/SK (modo proxy). (env>DB) Sem default.
HUAWEI_AK=<seu-ak-huawei>
HUAWEI_SK=<seu-sk-huawei>

# App key/secret padrão do tenant (usados como fallback do oauth_direct). (env>DB)
HUAWEI_APP_KEY=
HUAWEI_APP_SECRET=

# Modo de autenticação: proxy | oauth_direct. Default: proxy
HUAWEI_AUTH_MODE=oauth_direct

# URL do proxy de autorização (modo proxy). Default: proxy Teledata
HUAWEI_PROXY_URL=

# Credenciais do modo oauth_direct (tokenByAkSk). (env>DB) Sem default.
HUAWEI_DIRECT_APP_KEY=<seu-app-key-direct>
HUAWEI_DIRECT_APP_SECRET=<seu-app-secret-direct>

# Header X-TenantSpaceID opcional do oauth_direct. (env>DB) Sem default.
HUAWEI_TENANT_SPACE_ID=

# Base URL do serviço OAuth (sem porta 28443). Default: derivada do CMS_URL.
# HUAWEI_PORTAL_URL é o alias legado, ainda aceito.
HUAWEI_AUTH_BASE_URL=
HUAWEI_PORTAL_URL=

# Credenciais OBS (fallback direto no bucket quando o CC-FS retorna 0300012). (env>DB)
HUAWEI_OBS_AK=
HUAWEI_OBS_SK=
# Bucket OBS das gravações. Default: obs-nstech-opentech
HUAWEI_OBS_BUCKET=obs-nstech-opentech

# Verificação SSL das chamadas Huawei. Default: true (só desligue em diagnóstico)
HUAWEI_SSL_VERIFY=true

# Timezone p/ interpretar horários da API Huawei. Default: America/Sao_Paulo
HUAWEI_TIMEZONE=America/Sao_Paulo

# Pool HTTP do cliente Huawei. Defaults: 20 conexões / 10 keepalive / timeout 30.0s
HUAWEI_HTTP_MAX_CONNECTIONS=20
HUAWEI_HTTP_MAX_KEEPALIVE=10
HUAWEI_HTTP_TIMEOUT=30.0

# Janela (min) de cada queryCalls na descoberta. Default: 60
HUAWEI_QUERYCALLS_WINDOW_MINUTES=60

# Limite de downloads por ciclo. Vazio = usa a meta de auditorias
# (AUTOMATION_AUDIT_TARGET_COUNT, relação 1:1). Default interno: 20
HUAWEI_SYNC_MAX_DOWNLOAD_ATTEMPTS=

# Filtro de duração das ligações sincronizadas, em segundos.
# (env>DB) Defaults: min 120 / max 0 (0 = sem teto)
HUAWEI_SYNC_MIN_DURATION_SECONDS=120
HUAWEI_SYNC_MAX_DURATION_SECONDS=0

# Concorrência de downloads e de classificação no sync. Defaults: 5 / 5
HUAWEI_SYNC_DOWNLOAD_CONCURRENCY=5
HUAWEI_SYNC_CLASSIFY_CONCURRENCY=5

# Roda o classificador (LLM) logo após o sync. Default: false — a triagem
# classifica depois. HUAWEI_SYNC_SKIP_CLASSIFY é o legado invertido. [CUSTO]
HUAWEI_SYNC_ENABLE_CLASSIFY=false
HUAWEI_SYNC_SKIP_CLASSIFY=

# Confiança mínima p/ auto-auditar item vindo do sync. (env>DB) Default: 0.90
HUAWEI_AUTO_AUDIT_CONFIDENCE_THRESHOLD=0.90

# Descoberta apenas via OBS (pula CC-FS). Default: false
HUAWEI_DISCOVERY_OBS_ONLY=false

# Cobertura mínima do D-1 antes de alertar (0–1). Default: 0.8
HUAWEI_D_MINUS_1_COVERAGE_THRESHOLD=0.8

# Horas retroativas do script scripts/run_huawei_sync.py. Default: 1
HUAWEI_SYNC_HORAS_RETROATIVAS=1


# ------------------------------------------------------------------------------
# AUTOMAÇÃO (esteira pós-triagem: presta -> audita | não presta -> descarta)
# ------------------------------------------------------------------------------
# Liga o engine de automação in-process (cron interno no container). Default: false [CUSTO]
ENABLE_IN_PROCESS_AUTOMATION_ENGINE=false

# Meta de auditorias por ciclo (também dita o nº de downloads do sync).
# (env>DB: automacao_audit_target_count) Default: 3 [CUSTO]
AUTOMATION_AUDIT_TARGET_COUNT=3
# Nome legado da meta acima (ainda aceito como fallback).
AUTOMATION_AUDIT_BATCH_SIZE=

# Timeout (s) p/ auditar UM item (clamp 60–900). (env>DB) Default: 480
AUTOMATION_ITEM_TIMEOUT_SECONDS=480

# Estimativa (s) por item p/ derivar o batch do orçamento de tempo (clamp 30–900).
# (env>DB) Default: 180
AUTOMATION_EXPECTED_AUDIT_ITEM_SECONDS=180

# Orçamento de tempo (s) de um ciclo de auditoria (clamp 60–1800). (env>DB) Default: 480
AUTOMATION_AUDIT_TIME_BUDGET_SECONDS=480

# Flags da esteira binária (todas default ON; rollback setando =false):
# Auto-descarta item com alert_id='desconhecido' (não vai p/ triagem manual). Default: true
AUTOMATION_DISCARD_UNKNOWN_ALERTS=true
# Audita mesmo com risco de transcrição imperfeita (em vez de segurar). Default: true [CUSTO]
AUTOMATION_AUDIT_ON_TRANSCRIPTION_RISK=true
# Descarta item de operador bloqueado/não auditável. Default: true
AUTOMATION_DISCARD_BLOCKED_OPERATOR=true
# Ignora a cota mensal (2/operador) DURANTE a auditoria (cota vale só no envio). Default: true
AUTOMATION_AUDIT_IGNORE_MONTHLY_CAP=true
# Descarta item sem setor identificado. Default: true
AUTOMATION_DISCARD_MISSING_SECTOR=true
# Descarta item cujo alerta não tem critérios oficiais no banco. Default: true
AUTOMATION_DISCARD_NO_CRITERIA=true
# Descarta item de setor não-telefonia. Default: true
AUTOMATION_DISCARD_NON_TELEPHONY=true
# Descarta item com transcrição impossível (áudio inviável). Default: true
AUTOMATION_DISCARD_IMPOSSIBLE_TRANSCRIPTION=true
# Permite retry quando a transcrição falhou por motivo transitório. Default: true [CUSTO]
AUTOMATION_TRANSCRIPTION_FAILURE_RETRY=true

# Máximo de passagens pelo loop de descarte antes do tombstone. Default: 3
AUTOMATION_DISCARD_LOOP_LIMIT=3

# Tentativas p/ falha transitória (timeout/áudio/transcrição). 1 = SEM retry
# (não re-transcreve => não gasta Azure de novo). =3 restaura retry antigo.
# Default: 1 [CUSTO]
AUTOMATION_TRANSIENT_RETRY_LIMIT=1

# Não rebaixa item p/ 'pending' por baixa confiança (esteira decide). Default: true
AUTOMATION_SKIP_PENDING_ON_LOW_CONFIDENCE=true

# Cache (s) do snapshot de saúde da automação (corta queries no Neon). Default: 30
AUTOMATION_HEALTH_SNAPSHOT_TTL_SECONDS=30

# Idade (s) do heartbeat p/ considerar a automação travada. Default: 300
AUTOMATION_HEARTBEAT_STALE_SECONDS=300


# ------------------------------------------------------------------------------
# CRON E WEBHOOKS
# ------------------------------------------------------------------------------
# Token exigido nos endpoints de cron (/api/cron/* e automação via scheduler).
# OBRIGATÓRIO p/ habilitar disparo externo (Cloud Scheduler).
CRON_SECRET_TOKEN=<token-aleatorio-do-scheduler>

# Webhook chamado quando o fechamento D-1 da Huawei falha (vazio = desligado).
HUAWEI_D1_FAILURE_WEBHOOK_URL=


# ------------------------------------------------------------------------------
# STORAGE DE MÍDIA (áudios classificados e de auditoria)
# ------------------------------------------------------------------------------
# Backend de mídia: local | gcs. Vazio = auto (gcs em production/Cloud Run,
# local em dev). Default: auto
MEDIA_STORAGE_BACKEND=

# Raiz do storage local. Default: backend/storage
MEDIA_STORAGE_ROOT=

# Bucket GCS dos áudios. Default no Cloud Run: auditoria-nstech-audios
GCS_BUCKET_NAME=

# Diretórios LEGADOS de áudio local (ainda lidos p/ migração/compat):
# Default: backend/storage/classified_audio
CLASSIFIED_AUDIO_STORAGE_DIR=
# Default: backend/storage/audits/audio
AUDIT_AUDIO_STORAGE_DIR=


# ------------------------------------------------------------------------------
# SENTRY (monitoramento de erros)
# ------------------------------------------------------------------------------
# Liga/desliga o Sentry (qualquer valor != false liga, se houver DSN). Default: ligado se DSN
SENTRY_ENABLED=true
# DSN do projeto no Sentry. Vazio = Sentry desativado.
SENTRY_DSN=
# Ambiente reportado. Default: valor de ENVIRONMENT
SENTRY_ENVIRONMENT=development
# Sample rate de traces (0–1). Default: 0.05
SENTRY_TRACES_SAMPLE_RATE=0
# Sample rate de profiling (0–1, 0 desliga). Default: 0.0
SENTRY_PROFILES_SAMPLE_RATE=0
# Release reportado. Default: K_REVISION ou GIT_COMMIT_SHA (Cloud Run/CI)
SENTRY_RELEASE=


# ------------------------------------------------------------------------------
# E-MAIL (SMTP — envio de relatórios/avisos)
# ------------------------------------------------------------------------------
# Servidor e porta SMTP. Defaults: smtp.gmail.com / 587
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# Credenciais SMTP (vazio = envio desabilitado).
SMTP_USER=
SMTP_PASSWORD=<sua-senha-de-app-smtp>


# ------------------------------------------------------------------------------
# SQL SERVER READ-ONLY (REMOVIDO)
# ------------------------------------------------------------------------------
# As variáveis SQLSERVER_READONLY_* constavam de templates antigos, mas a
# integração NUNCA foi implementada no código (existe só o plano em
# docs/database/sqlserver-readonly-integration-plan.md). Não defina nada aqui.


# ------------------------------------------------------------------------------
# OUTROS / REDE / DEV
# ------------------------------------------------------------------------------
# Overrides de DNS "host=ip,host2=ip2" (workaround p/ DNS corporativo). Default: vazio
DNS_OVERRIDES=

# Força (true/false) o uso de proxies HTTP(S) do ambiente nas sessões requests.
# Vazio = auto (ignora proxy loopback quebrado :9). Default: auto
AUDITORIA_TRUST_ENV_PROXY=

# Variáveis injetadas pela plataforma (NÃO definir manualmente):
#   K_SERVICE / K_REVISION / K_CONFIGURATION  -> Cloud Run
#   GIT_COMMIT_SHA / COMMIT_SHA / SOURCE_COMMIT -> CI (release info)
#   HOSTNAME / PYTEST_CURRENT_TEST            -> runtime/testes

# --- Apenas testes e scripts utilitários (não usar em produção) ---
# Permite rodar a suíte de testes contra o banco de PRODUÇÃO (NÃO use!). Default: bloqueado
ALLOW_TESTS_ON_PROD_DB=
# Habilita fallback de critérios legado DENTRO de testes (exige pytest ativo). Default: false
AUDIT_ALLOW_OFFICIAL_CRITERIA_TEST_FALLBACK=
# Credenciais p/ scripts manuais de smoke (scripts/manual_test_audit.py).
BACKEND_TEST_USERNAME=
BACKEND_TEST_PASSWORD=
# Migração entre instâncias Neon (scripts/utils/migrate_neon_data.py).
OLD_DATABASE_URL=
NEW_DATABASE_URL=
# Pula geração de embeddings no sync de chunks RAG (scripts). Default: false
RAG_SKIP_EMBEDDINGS=
# Endpoint OBS p/ scripts de probe Huawei (scripts/test_obs_fallback.py).
HUAWEI_OBS_ENDPOINT=
# Nível de log do script run_huawei_sync.py. Default: INFO
HUAWEI_SYNC_LOG_LEVEL=INFO
