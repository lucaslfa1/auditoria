# Configuração KRONOS Backend - OFFICIAL TEMPLATE
# =================================================

# Chave mestra da API do Google Gemini
GEMINI_API_KEY=

# URL(s) permitida(s) no sistema de CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 1. Azure OpenAI - GPT-4o (Geral / Auditoria)
AZURE_OPENAI_ENDPOINT=https://azure-openai-opentech.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# 2. Diarização - Azure AI Services (Triagem / Diarize)
AZURE_GPT4O_DIARIZE_ENDPOINT=https://adml-mobl85rw-eastus2.cognitiveservices.azure.com/
AZURE_GPT4O_DIARIZE_KEY=
AZURE_GPT4O_DIARIZE_DEPLOYMENT=gpt-4o-transcribe-diarize
AZURE_GPT4O_DIARIZE_MODEL=gpt-4o-transcribe-diarize

# 3. Speech-to-Text padrão (Azure Fast Fallback)
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
AZURE_SPEECH_KEY=

# 4. Text Analytics (Language Service)
AZURE_TEXT_ANALYTICS_ENDPOINT=https://azure-language-opentech.cognitiveservices.azure.com/
AZURE_TEXT_ANALYTICS_KEY=

# 5. Whisper (Triagem Fallback)
AZURE_WHISPER_ENDPOINT=https://adml-mobl85rw-eastus2.cognitiveservices.azure.com/
AZURE_WHISPER_KEY=
AZURE_WHISPER_DEPLOYMENT=whisper

# Configurações Adicionais de IA
AI_PRIORITY=azure
ENABLE_AZURE_TRANSCRIPTION=true

# Autenticação e Sessão
SESSION_SECRET=dev-local-secret-key-change-in-production
AUTH_USERS_FILE=auth_users.json

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:pass@your-neon-pooler.neon.tech/dbname?sslmode=require

# Telefonia / Huawei AICC
# -----------------------
HUAWEI_CMS_URL=https://brazilsaas.aicccloud.com:28443
HUAWEI_FS_URL=https://brazilsaas.aicccloud.com:28443
HUAWEI_CC_ID=1
HUAWEI_VDN=25
HUAWEI_AK=
HUAWEI_SK=

# Modo de autenticacao Huawei AICC
HUAWEI_AUTH_MODE=oauth_direct
HUAWEI_DIRECT_APP_KEY=
HUAWEI_DIRECT_APP_SECRET=

# Chaveia a execucao do sync Huawei
ENABLE_HUAWEI_SYNC=false
HUAWEI_SYNC_HORAS_RETROATIVAS=1

# Automacao hibrida
ENABLE_IN_PROCESS_AUTOMATION_ENGINE=false

# Sentry Monitoring
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_RELEASE=
