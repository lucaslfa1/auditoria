{
  "name": "auditoria",
  "private": true,
  "version": "1.3.140",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloudrun.ps1",
    "up": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -OpenBrowser",
    "up:8080": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -OpenBrowser -Port 8080",
    "down": "powershell -ExecutionPolicy Bypass -File scripts/stop-local.ps1",
    "down:8080": "powershell -ExecutionPolicy Bypass -File scripts/stop-local.ps1 -Port 8080",
    "status": "powershell -ExecutionPolicy Bypass -File scripts/status-local.ps1",
    "status:8080": "powershell -ExecutionPolicy Bypass -File scripts/status-local.ps1 -Port 8080",
    "db:info": "backend\\.venv\\Scripts\\python.exe scripts/db_info.py",
    "db:migrate": "backend\\.venv\\Scripts\\python.exe scripts/db_migrate.py",
    "db:new-migration": "backend\\.venv\\Scripts\\python.exe scripts/create_db_migration.py",
    "db:importar-ligacoes": "backend\\.venv\\Scripts\\python.exe scripts/importar_ligacoes_auditadas.py",
    "db:importar-telefonia": "backend\\.venv\\Scripts\\python.exe backend/import_telefonia.py",
    "rag:sync-procedimentos": "backend\\.venv\\Scripts\\python.exe backend/scripts/sync_procedimento_chunks.py",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "node tests/frontend/frontend-regressions.test.mjs",
    "test:backend": "backend\\.venv\\Scripts\\python.exe -m pytest tests/backend -q",
    "log:new": "node scripts/new-log-version.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.100.9",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
