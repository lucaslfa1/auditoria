# Frontend
VITE_API_URL=http://localhost:8080
VITE_AI_API_KEY=

# PostgreSQL (Neon) — required for production persistence
# DATABASE_URL=postgresql://user:pass@your-neon-pooler.neon.tech/dbname?sslmode=require

# Shared backend values
ALLOWED_ORIGINS=http://localhost:5173
SESSION_SECRET=replace-with-a-strong-random-secret
SESSION_COOKIE_SECURE=false
# Required whenever an empty database is bootstrapped
AUTH_USERS_JSON=[{"username":"admin","password":"change-me"}]
AUTH_USERS_FILE=

# Sentry monitoring (backend; frontend errors go through /api/system/client-logs)
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_RELEASE=

# Optional AssemblyAI fallback (batch/pre-recorded)
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_API_BASE_URL=https://api.assemblyai.com/v2
ASSEMBLYAI_LANGUAGE_CODE=pt
ASSEMBLYAI_SPEAKER_LABELS=true
ASSEMBLYAI_SPEECH_MODEL=
ASSEMBLYAI_SPEECH_MODELS=universal-2
ASSEMBLYAI_BOOST_PARAM=high
ASSEMBLYAI_TIMEOUT_SECONDS=600
ASSEMBLYAI_POLL_INTERVAL_SECONDS=2
ASSEMBLYAI_FALLBACK=true

# Optional Azure Whisper controls
AZURE_TRANSCRIPTION_ENGINE=fast
TRANSCRIPTION_CANDIDATE_SELECTOR_ENABLED=true
AZURE_WHISPER_TEMPERATURE=0

# Optional Azure OpenAI diarized transcription fallback
AZURE_OPENAI_TRANSCRIBE_DIARIZE_DEPLOYMENT=
AZURE_GPT4O_DIARIZE_ENDPOINT=
AZURE_GPT4O_DIARIZE_KEY=
AZURE_GPT4O_DIARIZE_DEPLOYMENT=
AZURE_GPT4O_DIARIZE_AUTH_MODE=auto
AZURE_GPT4O_DIARIZE_MODEL=gpt-4o-transcribe-diarize
AZURE_GPT4O_DIARIZE_FALLBACK=true
AZURE_GPT4O_DIARIZE_MIN_SCORE=0.82
AZURE_GPT4O_DIARIZE_RETRY_COUNT=1
AZURE_GPT4O_DIARIZE_RETRY_DELAY_SECONDS=1.5
AZURE_GPT4O_DIARIZE_PRIMARY_SECTORS=
AZURE_GPT4O_DIARIZE_SMART_ROUTING=true
AZURE_GPT4O_DIARIZE_PRIMARY_PRESCAN_SECONDS=35
AZURE_GPT4O_DIARIZE_PRIMARY_PRESCAN_MIN_SCORE=0.58

# Runtime dependency: ffmpeg must be installed and available in PATH
# Required for smart routing audio prescan (extract_audio_excerpt)
# Install: https://ffmpeg.org/download.html or `choco install ffmpeg`

# Global API rate limiting (enabled by default in production)
ENABLE_GLOBAL_RATE_LIMIT=false
GLOBAL_RATE_LIMIT_MAX_REQUESTS=60
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60

# Optional SQL Server corporate read-only integration
SQLSERVER_READONLY_ENABLED=false
SQLSERVER_READONLY_HOST=
SQLSERVER_READONLY_PORT=1433
SQLSERVER_READONLY_DATABASE=
SQLSERVER_READONLY_SCHEMA=dbo
SQLSERVER_READONLY_USERNAME=
SQLSERVER_READONLY_PASSWORD=
SQLSERVER_READONLY_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_READONLY_ENCRYPT=true
SQLSERVER_READONLY_TRUST_SERVER_CERTIFICATE=false
SQLSERVER_READONLY_OPERATORS_VIEW=
SQLSERVER_READONLY_SYNC_MODE=manual
