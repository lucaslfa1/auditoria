# ==============================================================================
# Auditoria NSTECH — .env.example (RAIZ do repositório)
# ------------------------------------------------------------------------------
# Este arquivo cobre APENAS o que o frontend (Vite) e o dev local usam a partir
# da raiz. TODA a configuração do backend vive em backend/.env — veja o template
# completo e comentado em backend/.env.example.
#
# Observação: o backend TAMBÉM carrega o .env da raiz (override=False), então
# qualquer variável de backend definida aqui funciona como fallback — mas o
# padrão do projeto é mantê-las em backend/.env.
# ==============================================================================

# ------------------------------------------------------------------------------
# FRONTEND (Vite — variáveis VITE_* são expostas ao browser, nunca coloque segredo)
# ------------------------------------------------------------------------------
# URL do backend em dev. Usada como alvo do proxy /api do Vite e pelo apiClient
# quando rodando fora de produção. Default do código: http://localhost:8080
VITE_API_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# DEV LOCAL / TESTES (opcional — fallbacks lidos pelo backend e pela suíte)
# ------------------------------------------------------------------------------
# Connection string do Postgres para scripts/testes rodados a partir da raiz.
# A suíte de testes BLOQUEIA o banco de produção (guard no conftest) — use um
# banco de teste. NUNCA aponte testes para produção.
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Origens do CORS e segredo de sessão p/ subir o backend localmente sem
# backend/.env próprio (prefira configurar em backend/.env).
# ALLOWED_ORIGINS=http://localhost:5173
# SESSION_SECRET=<gere-um-segredo-forte-aleatorio>
# SESSION_COOKIE_SECURE=false

# Seed de usuários ao subir banco vazio em dev (lista JSON).
# AUTH_USERS_JSON=[{"username":"admin","password":"<troque-me>","role":"admin"}]
