.git
.gitignore
.dockerignore
.gcloudignore

node_modules/
dist/
dist-ssr/

# Python caching
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Virtual environments
.venv
.venv*/
backend/.venv
backend/.venv*/
venv/
env/

# Data and large files
*.db
*.sqlite
*.sqlite3
backend/auditoria.db
backend/data/

# Audio and media
*.wav
*.mp3
*.m4a
*.mp4
*.ogg
*.flac

# Env and sensitive
.env
.env.*
backend/.env
backend/.env.*
backend/auth_users.json
backend/gcp-key.json

# Logs and scratch
logs/*
!logs/versions/
!logs/versions/*.md
tmp/
.temp/
.cache/
*.log
*_log*.txt
*.txt
!backend/requirements.txt
!auditoria_criterios/**/*.txt

# AI agents
.gemini/
.agent/
.claude/
.Jules/
.gcloud/

# Excel and scratch files
docs/~$*
docs/
scratch_*.py

